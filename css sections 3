<!DOCTYPE html>
<html>
<head>
 

<style>*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

body{
    font-family:Arial;
    background:#f5f5f5;
}
.container{
    width:90%;
    margin:50px auto;
    text-align:center;
}

h1{
    font-weight:normal;
}

.line{
    width:70px;
    height:3px;
    background:orange;
    margin:20px auto;
}
p{
    color:gray;
    margin-bottom:50px;
}

.card{
    width:28%;
    display:inline-block;
    vertical-align:top;
    background:white;
    margin:10px;
}
.head{
    background:#333;
    color:white;
    padding:20px;
    font-size:25px;
}

.price{
    background:#333;
    color:white;
    padding:20px;
    border-bottom:4px solid orange;}

.price h2{
    font-size:60px;}

.popular{
    background:orange;
    color:white;
    padding:10px;
    font-weight:bold;
}
.card ul{
    list-style:none;
}

.card li{
    padding:15px;
    border-bottom:1px solid #ddd;
    color:gray;
}

</style>

</head>

<body>

<div class="container">

<h1>PRICING OPTIONS</h1>
<div class="line"></div>
<p>Lorem ipsum dolor sit amet, consectetur adipisicing elit.</p>

<div class="card">
<div class="head">Basic</div>
<div class="price">
<h2>$0</h2>
Free for Life
</div>

<ul>
<li>1 GB OF SPACE</li>
<li>10 GB OF BANDWIDTH</li>
<li>3 WEBSITES</li>
<li>BASIC CUSTOMIZATION</li>
<li>WORDPRESS INTEGRATION</li>
<li>EMAIL SUPPORT</li>
</ul>
</div>

<div class="card">
<div class="head">Professional</div>
<div class="price">
<h2>$19</h2>
Monthly Payment
</div>

<div class="popular">
OUR MOST POPULAR
</div>

<ul>
<li>5 GB OF SPACE</li>
<li>50 GB OF BANDWIDTH</li>
<li>12 WEBSITES</li>
<li>ADVANCED CUSTOMIZATION</li>
<li>WORDPRESS INTEGRATION</li>
<li>EMAIL SUPPORT</li>
</ul>

</div>

<div class="card">
<div class="head">Enterprise</div>
<div class="price">
<h2>$70</h2>
Monthly Payment
</div>

<ul>
<li>UNLIMITED SPACE</li>
<li>UNLIMITED BANDWIDTH</li>
<li>100 WEBSITES</li>
<li>ADVANCED CUSTOMIZATION</li>
<li>WORDPRESS INTEGRATION</li>
<li>24/7 CUSTOMER SUPPORT</li>
</ul>
</div>
</div>
</body>
</html>
