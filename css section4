<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
<style>   
   *{
    margin:0;
    padding:0;
    box-sizing:border-box;
} 
.container{
    width:80%;
    margin:auto;
} 
.navbar{
    background:black;
    padding:20px 0;
} 
.logo{
    float:left;
} 
.menu{
    float:right;
    list-style:none;
}
.menu li{
    display:inline-block;
    margin-left:30px;
}
.menu a{
    color:white;
    text-decoration:none;
}
.clear{
    clear:both;
}
.hero{
    background-image:url("https://images.unsplash.com/photo-1449824913935-59a10b8d2000?auto=format&fit=crop&w=1600&q=80");
    background-size:cover;
    background-position:center;
}
.left{
    float:left;
    width:50%;
    color:white;
}
.left img{
    width:120px;
}
.left h1{
    margin:20px 0;
}
.left p{
    margin:20px 0;
}
.left button{
    background:transparent;
    color:white;
    border:2px solid white;
    padding:10px 25px;
}
.right{
    float:right;
    width:35%;
}
.form{
    background:white;
    text-align:center;
    width: 200px;
}
.form h2{
    background:#f5f5f5;
    padding:20px;
}
.form span{
    color:orange;
}
.form input{
    width:80%;
    padding:12px;
    margin:20px;
    border:none;
    border-bottom:1px solid gray;
}
.form button{
    width:100%;
    padding:15px;
    background:orange;
    color:white;
    border:none;
} 
.overlay{
    background-color: rgba(0,0,0,0.5);
    height:100%;
    width:100%;
      padding: 100px 100px;
}
</style>

</head>
<body> 
      <nav class="navbar">
    <div class="container">
         <img src="https://placehold.co/120x40/000000/FFFFFF?text=LOGO"  alt="axure" width="120" class="logo">
        <ul class="menu">
            <li><a href="">Features</a></li>
            <li><a href="">About</a></li>
            <li><a href="">Pricing</a></li>
            <li><a href="">Reviews</a></li>
            <li><a href="">Contact</a></li>
        </ul>
        <div class="clear"></div>
    </div>
</nav>

<section class="hero">
        <div class="overlay"> 
    <div class="container">
        <div class="left">
             <img src="https://placehold.co/120x40/000000/FFFFFF?text=LOGO"  alt="axure" width="120"> 
            <h1>
                MODERN AXURE TEMPLATE <br>
                FOR BEAUTIFUL PROTOTYPES
            </h1>
            <hr>
            <p>
                Lorem ipsum dolor sit amet, consectetur adipisicing elit.
                Aenean euismod bibendum laoreet.
            </p>
            <button>Download</button>
        </div>
        <div class="right">
            <div class="form">
                <h2>Try Your <span>FREE</span> Trial Today</h2>
                <input type="text" placeholder="Name">
                <input type="email" placeholder="Email">
                <input type="password" placeholder="Password">
                <button class="btn">Get Started</button>
            </div>
        </div>
        <div class="clear"></div>
    </div>
    </div>
</section>
</body>
</html>
