<!DOCTYPE html>
<html>
<head>
 

<style> 
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

body{
    font-family:Arial;
}

.container{
    width:90%;
    margin:50px auto;
    text-align:center;
}

h1{
    font-size:45px;
    font-weight:normal;
}

.line{
    width:70px;
    height:3px;
    background:orange;
    margin:20px auto;
}

p{
    color:gray;
    margin-bottom:60px;
}

.left,
.right{
    display:inline-block;
    vertical-align:top;
    width:48%;
}

input,
textarea{
    width:90%;
    border:none;
    border-bottom:1px solid gray;
    padding:15px;
    margin-bottom:25px;
    font-size:16px;
}

textarea{
    height:170px;
    resize:none;
}

button{
    background:orange;
    color:white;
    border:none;
    padding:15px 30px;
    font-size:18px;
    margin-top:20px;
}

</style></head>

<body>
<div class="container">
<h1>CONTACT US</h1>
<div class="line"></div>
<p>Lorem ipsum dolor sit amet, consectetur adipisicing elit.</p>
<div class="left">
<input type="text" placeholder="Name">
<input type="email" placeholder="Email">
<input type="text" placeholder="Subject">

</div>

<div class="right">

<textarea placeholder="Message"></textarea>

</div>
<br>
<button>Send Message</button>
</div>

</body>
</html>
