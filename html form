<!DOCTYPE html>
<html>
<body> 
    <fieldset>
     
    <form>
        <label>first name: </label>
        <input type="text" name="fname" maxlength="5" pattern="[A-Za-z]+" required>
        <br><br>
         <label>email: </label>
        <input type="email"required name="email" >
        <br><br>
         <label>phone: </label>
         <input type="text" maxlength="11" name="phone" pattern="01[0125][0-9]{8}" required>
        <br><br>
          <label>File:</label>
     <input type="file" name="img" accept=".png" required>
    <br><br>
    <label>Courses:</label> 
<input type="text" name="course" list="courses">

<datalist id="courses">
    <option value="html">
    <option value="css">
    <option value="js">
</datalist>
<br><br>
<label>date:</label>
<input type="date" required name="date">
<br><br>
<label>Comment:</label>
<textarea required></textarea>
<br><br>
 <label>gender:</label>
 <input type="radio" value="male" name="gender">male
<input type="radio" value="female" name="gender">female
<br><br>
<label>tracks:</label>
<input type="checkbox" >frontend
<br><br>
<input type="checkbox" >backend
<br><br>
<input type="checkbox" >data science
<br><br>
<input type="checkbox" >ai
<br><br>
<button>submit</button>
<br><br>
<button>reset</button>
<br><br>




    </form>
 </fieldset>
</body>
</html>